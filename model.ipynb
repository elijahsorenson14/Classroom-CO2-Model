import numpy as np
import matplotlib.pyplot as plt


C_out = 420          # outdoor CO2 (ppm)
C0 = 420             # initial indoor CO2 (ppm)

G = 0.004            # CO2 generation rate per person (ppm/s scaled)
n_people = 25
V = 180              # room volume (m^3)
ACH = 1.2            # air changes per hour

k = ACH / 3600       # convert to per second
G_total = G * n_people


dt = 1               # seconds
T = 3 * 3600         # simulate 3 hours
steps = int(T / dt)

C = np.zeros(steps)
C[0] = C0

for t in range(1, steps):
    dCdt = (G_total / V) - k * (C[t-1] - C_out)
    C[t] = C[t-1] + dCdt * dt


time = np.arange(steps) / 3600  # hours

plt.plot(time, C)
plt.xlabel("Time (hours)")
plt.ylabel("CO2 concentration (ppm)")
plt.title("Indoor CO2 Buildup in Classroom")
plt.axhline(1000, linestyle="--", color="red")
plt.show()
